{
  "id": "devops/helm",
  "family": "devops-cli",
  "description": "Compact Helm output while preserving rendered-resource errors, release status, and upgrade failures.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["helm"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 14,
    "tail": 12
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 20,
    "tail": 20
  },
  "counters": [
    {
      "name": "resource",
      "pattern": "^kind: |^# Source:",
      "flags": "m"
    },
    {
      "name": "error",
      "pattern": "Error:|failed|UPGRADE FAILED|INSTALLATION FAILED",
      "flags": "i"
    }
  ]
}
