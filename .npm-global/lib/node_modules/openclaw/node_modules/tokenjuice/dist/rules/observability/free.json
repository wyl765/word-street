{
  "id": "observability/free",
  "family": "resource-memory",
  "description": "Compact free output while preserving memory and swap totals.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["free"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "warning",
      "pattern": "error|failed",
      "flags": "i"
    }
  ]
}
