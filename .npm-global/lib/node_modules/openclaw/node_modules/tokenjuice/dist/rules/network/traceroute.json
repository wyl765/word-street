{
  "id": "network/traceroute",
  "family": "network-route",
  "description": "Compact traceroute output while preserving hop rows and failures.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["traceroute"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 12
  },
  "counters": [
    {
      "name": "hop",
      "pattern": "^\\s*\\d+\\s",
      "flags": "m"
    }
  ]
}
