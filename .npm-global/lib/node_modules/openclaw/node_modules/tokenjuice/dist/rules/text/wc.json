{
  "id": "text/wc",
  "family": "text-processing",
  "description": "Compact wc output while preserving counts and read errors.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["wc"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "count",
      "pattern": "^\\s*\\d+",
      "flags": "m"
    },
    {
      "name": "error",
      "pattern": "No such file|Permission denied|cannot open",
      "flags": "i"
    }
  ]
}
