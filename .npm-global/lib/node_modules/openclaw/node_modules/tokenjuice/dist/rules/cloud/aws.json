{
  "id": "cloud/aws",
  "family": "cloud-cli",
  "description": "Compact AWS CLI output while preserving result rows and service errors.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["aws"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|exception|denied|not found",
      "flags": "i"
    }
  ]
}
