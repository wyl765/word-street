{
  "id": "build/tsdown",
  "family": "build-bundler",
  "description": "Compact tsdown build output while preserving warnings and failures.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["tsdown"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error",
      "flags": "i"
    },
    {
      "name": "warning",
      "pattern": "warning",
      "flags": "i"
    }
  ]
}
