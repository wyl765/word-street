{
  "id": "build/maven",
  "family": "build-jvm",
  "description": "Compact Maven output while preserving errors, failed goals, and reactor summaries.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["mvn", "mvnw", "./mvnw"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 12
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 18,
    "tail": 18
  },
  "counters": [
    {
      "name": "error",
      "pattern": "\\[ERROR\\]|BUILD FAILURE|Failed to execute goal",
      "flags": "i"
    },
    {
      "name": "warning",
      "pattern": "\\[WARNING\\]",
      "flags": "i"
    }
  ]
}
