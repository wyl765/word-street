{
  "id": "system/ps",
  "family": "system-processes",
  "description": "Compact ps output while preserving process rows.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["ps"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 10
  },
  "counters": [
    {
      "name": "process",
      "pattern": "^(?!USER\\s|PID\\s).+\\S.*$"
    }
  ]
}
