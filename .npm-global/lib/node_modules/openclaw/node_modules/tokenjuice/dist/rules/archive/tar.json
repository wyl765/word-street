{
  "id": "archive/tar",
  "family": "archive-cli",
  "description": "Compact tar output while preserving archive paths and error lines.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["tar"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed|cannot",
      "flags": "i"
    }
  ]
}
