{
  "id": "tests/vitest",
  "family": "test-results",
  "description": "Compact Vitest output while preserving failures and summary lines.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["vitest"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "skipPatterns": [
      "^\\s*at .+",
      "^\\s*❯ .+node_modules.+",
      "^\\s*✓ .+"
    ],
    "keepPatterns": [
      "^\\s*RUN\\s+",
      "^\\s*❯\\s+.+",
      "^\\s*FAIL\\s+.+",
      "^AssertionError: .+",
      "^Error: .+",
      "^Caused by: .+",
      "^\\s*Test Files\\s+.+",
      "^\\s*Tests\\s+.+",
      "^   Start at\\s+.+",
      "^   Duration\\s+.+",
      "^⎯⎯⎯.+"
    ]
  },
  "summarize": {
    "head": 10,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "failed suite",
      "pattern": "^\\s*❯\\s.+",
      "flags": "m"
    },
    {
      "name": "failure",
      "pattern": "failed",
      "flags": "i"
    }
  ]
}
