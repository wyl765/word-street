{
  "id": "git/show",
  "family": "git-show",
  "description": "Compact git show output while preserving commit summary and diff stat.",
  "match": {
    "argv0": ["git"],
    "argvIncludes": [["show"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "keepPatterns": [
      "^commit\\s+.+",
      "^Author:\\s+.+",
      "^Date:\\s+.+",
      "^\\s{4}.+",
      "^diff --git\\s+.+",
      "^index\\s+[a-f0-9]+\\.[a-f0-9]+",
      "^---\\s+.+",
      "^\\+\\+\\+\\s+.+",
      "^@@\\s+.+",
      "^\\s*\\d+ files? changed.+",
      "^\\s*create mode .+",
      "^\\s*delete mode .+"
    ]
  },
  "summarize": {
    "head": 8,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "file",
      "pattern": "\\|"
    },
    {
      "name": "commit",
      "pattern": "^commit\\s",
      "flags": "m"
    }
  ]
}
