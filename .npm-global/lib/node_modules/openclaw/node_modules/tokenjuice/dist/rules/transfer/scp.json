{
  "id": "transfer/scp",
  "family": "file-transfer",
  "description": "Compact scp output while preserving transferred paths, throughput, and ssh failures.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["scp"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed|permission denied|lost connection",
      "flags": "i"
    }
  ]
}
