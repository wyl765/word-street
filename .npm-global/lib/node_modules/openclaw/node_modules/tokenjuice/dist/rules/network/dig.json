{
  "id": "network/dig",
  "family": "network-dns",
  "description": "Compact dig output while preserving answer sections and failures.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["dig"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "answer",
      "pattern": "ANSWER SECTION|\\sIN\\sA\\s|\\sIN\\sAAAA\\s",
      "flags": "i"
    }
  ]
}
