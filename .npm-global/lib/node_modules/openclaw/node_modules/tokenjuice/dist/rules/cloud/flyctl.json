{
  "id": "cloud/flyctl",
  "family": "deploy-cli",
  "description": "Compact Fly output while preserving machine, app, and rollout status lines.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["fly", "flyctl"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed|unhealthy|warning",
      "flags": "i"
    }
  ]
}
