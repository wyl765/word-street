{
  "id": "database/mongosh",
  "family": "database-cli",
  "description": "Compact mongosh output while preserving collection results and query errors.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["mongosh"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed|exception",
      "flags": "i"
    }
  ]
}
