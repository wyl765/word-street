{
  "id": "filesystem/fd",
  "family": "filesystem-inventory",
  "description": "Compact fd output while preserving matching paths and errors.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["fd", "fdfind"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 10
  },
  "counters": [
    {
      "name": "path",
      "pattern": "^(?!(fd: |\\[fd error\\]: )).+\\S.*$"
    },
    {
      "name": "error",
      "pattern": "^(fd: |\\[fd error\\]: )"
    }
  ]
}
