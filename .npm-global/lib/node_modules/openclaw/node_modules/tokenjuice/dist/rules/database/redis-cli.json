{
  "id": "database/redis-cli",
  "family": "database-cli",
  "description": "Compact redis-cli output while preserving command replies and connection failures.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["redis-cli"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|denied|could not connect",
      "flags": "i"
    }
  ]
}
