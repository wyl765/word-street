{
  "id": "search/grep",
  "family": "search",
  "description": "Compact grep output while preserving matching lines.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["grep"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "keepPatterns": [
      "^.+:\\d+[: -].+",
      "^.+:.+",
      "error|warn|binary file|permission denied|no such file",
      "^\\d+ matches?$",
      "^\\d+ files? matched$"
    ]
  },
  "summarize": {
    "head": 10,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 12
  },
  "counters": [
    {
      "name": "match",
      "pattern": ".+:.+"
    }
  ]
}
