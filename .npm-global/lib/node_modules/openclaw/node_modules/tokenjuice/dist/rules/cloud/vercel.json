{
  "id": "cloud/vercel",
  "family": "deploy-cli",
  "description": "Compact Vercel CLI output while preserving deployment URLs and error details.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["vercel"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed|canceled|timed out",
      "flags": "i"
    }
  ]
}
