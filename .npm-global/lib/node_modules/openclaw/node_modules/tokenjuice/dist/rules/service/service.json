{
  "id": "service/service",
  "family": "service-state",
  "description": "Compact service command output while preserving status and failure lines.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["service"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "keepPatterns": [
      "error|failed|inactive|stopped|warning|refused|timeout",
      "is running",
      "is stopped",
      "start/running",
      "stop/waiting",
      "^\\s*Active:\\s+.+",
      "^\\s*Status:\\s+.+"
    ]
  },
  "summarize": {
    "head": 8,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "warning",
      "pattern": "warning|refused|timeout",
      "flags": "i"
    },
    {
      "name": "error",
      "pattern": "error|failed|inactive|stopped",
      "flags": "i"
    }
  ]
}
