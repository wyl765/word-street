{
  "id": "service/lsof",
  "family": "service-open-files",
  "description": "Compact lsof output while preserving open-file rows.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["lsof"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "entry",
      "pattern": "^(?!COMMAND\\s+PID\\s+USER\\s).+\\S.*$"
    }
  ]
}
