{
  "id": "network/nslookup",
  "family": "network-dns",
  "description": "Compact nslookup output while preserving server and answer rows.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["nslookup"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "server",
      "pattern": "^Server:",
      "flags": "m"
    }
  ]
}
