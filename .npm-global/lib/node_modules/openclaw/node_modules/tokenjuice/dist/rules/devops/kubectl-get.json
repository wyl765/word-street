{
  "id": "devops/kubectl-get",
  "family": "kubernetes-list",
  "description": "Compact kubectl get output while preserving resource rows.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["kubectl"],
    "argvIncludes": [["get"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "skipPatterns": [
      "^No resources found"
    ]
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 12
  },
  "counters": [
    {
      "name": "resource",
      "pattern": "^(?!NAME\\s).+\\S.*$"
    }
  ]
}
