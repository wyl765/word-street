{
  "id": "network/wget",
  "family": "network-http",
  "description": "Compact wget output while preserving transfer summary and failures.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["wget"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed",
      "flags": "i"
    }
  ]
}
