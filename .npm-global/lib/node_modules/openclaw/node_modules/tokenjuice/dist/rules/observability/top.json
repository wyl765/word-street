{
  "id": "observability/top",
  "family": "resource-processes",
  "description": "Compact top output while preserving load, task counts, and leading process rows.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["top"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 12
  },
  "counters": [
    {
      "name": "warning",
      "pattern": "load average|zombie|stopped",
      "flags": "i"
    }
  ]
}
