{
  "id": "transfer/rsync",
  "family": "file-transfer",
  "description": "Compact rsync output while preserving changed paths, stats, and sync failures.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["rsync"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed|connection|sent ",
      "flags": "i"
    }
  ]
}
