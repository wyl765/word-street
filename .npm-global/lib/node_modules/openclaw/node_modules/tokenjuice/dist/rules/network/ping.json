{
  "id": "network/ping",
  "family": "network-probe",
  "description": "Compact ping output while preserving packet loss and latency summary.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["ping"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 12
  },
  "counters": [
    {
      "name": "reply",
      "pattern": "bytes from",
      "flags": "i"
    },
    {
      "name": "packet loss",
      "pattern": "packet loss",
      "flags": "i"
    }
  ]
}
