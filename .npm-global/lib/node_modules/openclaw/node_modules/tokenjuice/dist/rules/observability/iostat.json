{
  "id": "observability/iostat",
  "family": "resource-io",
  "description": "Compact iostat output while preserving CPU averages and busy devices.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["iostat"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 12
  },
  "counters": [
    {
      "name": "busy",
      "pattern": "%util|Device",
      "flags": "i"
    }
  ]
}
