{
  "id": "lint/eslint",
  "family": "lint-results",
  "description": "Compact ESLint output while preserving file diagnostics and summary counts.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["eslint"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "keepPatterns": [
      "^.+\\.(ts|tsx|js|jsx|mjs|cjs)$",
      "^\\s*\\d+:\\d+\\s+(error|warning)\\s+.+",
      "^✖\\s+.+",
      "^\\d+ problems?\\s+\\(.+\\)$",
      "^\\s*error\\s+.+",
      "^\\s*warning\\s+.+"
    ]
  },
  "summarize": {
    "head": 10,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "\\berror\\b",
      "flags": "i"
    },
    {
      "name": "warning",
      "pattern": "\\bwarning\\b",
      "flags": "i"
    }
  ]
}
