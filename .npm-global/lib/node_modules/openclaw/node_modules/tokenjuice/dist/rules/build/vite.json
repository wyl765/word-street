{
  "id": "build/vite",
  "family": "build-bundler",
  "description": "Compact vite build output while preserving warnings and failures.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["vite", "build"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "skipPatterns": [
      "^transforming \\(.+\\) .+",
      "^rendering chunks \\(.+\\) .+",
      "^computing gzip size \\(.+\\) .+"
    ]
  },
  "summarize": {
    "head": 12,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error",
      "flags": "i"
    },
    {
      "name": "warning",
      "pattern": "warning",
      "flags": "i"
    }
  ]
}
