{
  "id": "devops-kubectl-get-basic",
  "ruleId": "devops/kubectl-get",
  "input": {
    "toolName": "exec",
    "argv": ["kubectl", "get", "pods"],
    "command": "kubectl get pods",
    "combinedText": "NAME        READY   STATUS    RESTARTS\napi-123     1/1     Running   0\n",
    "exitCode": 0
  },
  "expect": {
    "matchedReducer": "devops/kubectl-get",
    "family": "kubernetes-list",
    "contains": ["resource", "api-123"]
  }
}
