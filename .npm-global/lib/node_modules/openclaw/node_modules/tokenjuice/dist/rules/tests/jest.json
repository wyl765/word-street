{
  "id": "tests/jest",
  "family": "test-results",
  "description": "Compact Jest output while preserving failures and summary counts.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["jest"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "skipPatterns": [
      "^\\s*at .+",
      "^Ran all test suites.*$"
    ]
  },
  "summarize": {
    "head": 12,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 16
  },
  "counters": [
    {
      "name": "failed test",
      "pattern": "^FAIL\\s",
      "flags": "m"
    },
    {
      "name": "passed suite",
      "pattern": "^PASS\\s",
      "flags": "m"
    }
  ]
}
