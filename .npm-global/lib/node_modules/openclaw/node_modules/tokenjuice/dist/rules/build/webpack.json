{
  "id": "build/webpack",
  "family": "build-bundler",
  "description": "Compact webpack output while preserving module errors and warnings.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["webpack"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "keepPatterns": [
      "^Entrypoint\\s+.+",
      "^ERROR in .+",
      "^WARNING in .+",
      "^Module .+",
      "^\\s*ERROR\\s+in\\s+.+",
      "^\\s*webpack\\s+\\d+\\.\\d+\\.\\d+ compiled .+",
      "^\\s*\\d+ errors? have detailed information.+"
    ]
  },
  "summarize": {
    "head": 4,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 4,
    "tail": 8
  },
  "counters": [
    {
      "name": "asset",
      "pattern": "^asset\\s+.+",
      "flags": "m"
    },
    {
      "name": "error",
      "pattern": "error",
      "flags": "i"
    },
    {
      "name": "warning",
      "pattern": "warning",
      "flags": "i"
    }
  ]
}
