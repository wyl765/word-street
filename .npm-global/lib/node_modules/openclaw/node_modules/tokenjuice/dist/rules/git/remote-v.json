{
  "id": "git/remote-v",
  "family": "git-remote",
  "description": "Compact git remote -v output while preserving fetch/push remotes.",
  "match": {
    "argv0": ["git"],
    "argvIncludes": [["remote"], ["-v"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 10,
    "tail": 4
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 10
  },
  "counters": [
    {
      "name": "remote",
      "pattern": "\\((fetch|push)\\)"
    }
  ]
}
