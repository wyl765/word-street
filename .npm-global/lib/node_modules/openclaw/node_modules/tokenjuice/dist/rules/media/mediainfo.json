{
  "id": "media/mediainfo",
  "family": "media-cli",
  "description": "Compact mediainfo output while preserving format, duration, and stream details.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["mediainfo"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "warning",
      "pattern": "error|failed|duration|format",
      "flags": "i"
    }
  ]
}
