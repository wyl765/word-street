{
  "id": "tests/go-test",
  "family": "test-results",
  "description": "Compact go test output while preserving failing packages and summaries.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["go"],
    "argvIncludes": [["test"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "skipPatterns": [
      "^ok\\s.+"
    ],
    "keepPatterns": [
      "^FAIL\\s.+",
      "^--- FAIL: .+",
      "^panic: .+",
      "^\\s+.+_test\\.go:\\d+: .+",
      "^\\s+Error Trace: .+",
      "^\\s+Error: .+"
    ]
  },
  "summarize": {
    "head": 10,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "failed package",
      "pattern": "^FAIL\\s",
      "flags": "m"
    },
    {
      "name": "passed package",
      "pattern": "^ok\\s",
      "flags": "m"
    }
  ]
}
