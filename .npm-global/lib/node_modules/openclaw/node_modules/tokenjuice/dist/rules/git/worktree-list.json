{
  "id": "git/worktree-list",
  "family": "git-worktree",
  "description": "Compact git worktree list output while preserving worktree entries.",
  "match": {
    "argv0": ["git"],
    "gitSubcommands": ["worktree"],
    "argvIncludes": [["list"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 4
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 12,
    "tail": 10
  },
  "counters": [
    {
      "name": "worktree",
      "pattern": "^/\\S",
      "flags": "m"
    }
  ]
}
