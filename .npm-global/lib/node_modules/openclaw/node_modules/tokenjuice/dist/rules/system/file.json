{
  "id": "system/file",
  "family": "file-inspection",
  "description": "Compact file output while preserving the detected file type.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["file"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "warning",
      "pattern": "cannot open|error",
      "flags": "i"
    }
  ]
}
