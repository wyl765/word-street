{
  "id": "git/log-oneline",
  "family": "git-history",
  "description": "Compact git log --oneline output while preserving commits.",
  "match": {
    "argv0": ["git"],
    "argvIncludes": [["log"], ["--oneline"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "commit",
      "pattern": "^[a-f0-9]{7,}\\s",
      "flags": "m"
    }
  ]
}
