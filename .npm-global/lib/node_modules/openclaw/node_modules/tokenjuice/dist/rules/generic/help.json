{
  "id": "generic/help",
  "family": "help",
  "description": "Preserve command help output so agents can inspect available commands and flags.",
  "priority": 25,
  "match": {
    "toolNames": ["exec"],
    "argvIncludesAny": [["--help"], ["help"]],
    "commandIncludesAny": [" --help", " help"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 80,
    "tail": 40
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 80,
    "tail": 40
  }
}
