{
  "id": "database/sqlite3",
  "family": "database-cli",
  "description": "Compact sqlite3 output while preserving query rows and parse errors.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["sqlite3"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 8,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 10,
    "tail": 10
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed|no such table",
      "flags": "i"
    }
  ]
}
